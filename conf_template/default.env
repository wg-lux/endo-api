# Endo API .env template (reference)
# Precedence: OS environment > .env > defaults
# Do NOT commit real secrets to version control.

# -----------------------------------------------------------------------------
# Core application
# -----------------------------------------------------------------------------
DJANGO_ENV=development  # development|production
DJANGO_SETTINGS_MODULE=endo_api.settings_dev
DJANGO_MODULE=endo_api
BASE_URL=http://127.0.0.1:8118
DJANGO_HOST=127.0.0.1
DJANGO_PORT=8118
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Secrets (replace in production)
DJANGO_SECRET_KEY=replace-me-in-production

# Paths
DATA_DIR=./data
STORAGE_DIR=./data
WORKING_DIR=.

# Logging
FILE_LOG_LEVEL=INFO

# Tests
RUN_VIDEO_TESTS=true

# -----------------------------------------------------------------------------
# Database (development)
# Development uses SQLite by default via settings_dev.py
# Optional override example:
# DATABASE_ENGINE=sqlite
# DATABASE_NAME=./data/db.sqlite3

# -----------------------------------------------------------------------------
# Database (production) — choose ONE approach
# Priority: DATABASE_URL > DB_*
# 1) Single URL (recommended)
# DATABASE_URL=postgresql://USER:PASS@DB_HOST:5432/DB_NAME
# 2) Explicit fields
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=endo
# DB_USER=endo
# DB_PASSWORD=supersecret
# DB_HOST=db-host
# DB_PORT=5432
# Optional SSL via env
# DB_SSLMODE=require
# DB_SSLROOTCERT_B64=BASE64_PEM
# DB_SSLCERT_B64=BASE64_PEM
# DB_SSLKEY_B64=BASE64_PEM
# Or JSON options (takes precedence over the above when set)
# DJANGO_DB_OPTIONS={"sslmode":"require"}

# -----------------------------------------------------------------------------
# Security flags (production)
# -----------------------------------------------------------------------------
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Central node (managed deployments)
# -----------------------------------------------------------------------------
# CENTRAL_NODE=false
