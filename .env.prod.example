# Production Environment Configuration
# Copy this to .env.prod for production deployment

# Application Mode
ENDO_API_MODE=production

# Django Settings
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,localhost,0.0.0.0
DJANGO_SECRET_KEY=your-production-secret-key-here
DJANGO_SALT=your-production-salt-here

# Server Configuration
DJANGO_HOST=0.0.0.0
DJANGO_PORT=8118
DJANGO_MODULE=endo_api

# Database Configuration (PostgreSQL)
DATABASE_ENGINE=postgresql
DATABASE_HOST=postgres  # or your external postgres host
DATABASE_PORT=5432
DATABASE_NAME=endoregDbLocal
DATABASE_USER=endoregDbLocal
# DATABASE_PASSWORD is read from conf/db_pwd file

# Redis Configuration
REDIS_HOST=redis  # or your external redis host
REDIS_PORT=6379

# Storage Paths (inside container)
DATA_DIR=/app/data
CONF_DIR=/app/conf
WORKING_DIR=/app
STORAGE_DIR=/app/data
IMPORT_DIR=/app/data/import

# Application Settings
RUST_BACKTRACE=1
DJANGO_FFMPEG_EXTRACT_FRAME_BATCHSIZE=500
LABEL_VIDEO_SEGMENT_MIN_DURATION_S_FOR_ANNOTATION=3

# Security Settings (Production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
