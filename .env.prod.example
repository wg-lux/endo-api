# Production Environment Configuration
# Copy this to .env.prod for production deployment
# 
# NOTE: Most configuration is now handled by app_config.nix and conf/db.yaml
# This file contains only environment-specific overrides

# Application Mode
ENDO_API_MODE=production

# Django Settings (Required)
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS="your-domain.com,localhost"
DJANGO_SECRET_KEY="your-production-secret-key-here"
DJANGO_SALT="your-production-salt-here"

# Database Configuration (Required)
# Points to the database configuration file
DB_CONFIG_FILE="conf/db.yaml"

# Server Configuration (Optional - overrides app_config.nix)
# DJANGO_HOST=0.0.0.0  # Uncomment for container deployments
# DJANGO_PORT=8118     # Uncomment to override default port

# Testing Configuration (Optional)
# RUN_VIDEO_TESTS=false  # Set to false to skip video tests in production

# Central Node Configuration (Optional - for luxnix managed deployments)
# CENTRAL_NODE=false  # Set to true if this is a central coordination node

# Django Settings Module (Managed automatically - do not change)
DJANGO_SETTINGS_MODULE=endo_api.settings_prod
