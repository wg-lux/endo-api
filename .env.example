# Canonical environment configuration for Endo API

# Core
DJANGO_ENV=development  # development|production
DJANGO_DEBUG=           # optional; defaults true in development, false in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_HOST=0.0.0.0
DJANGO_PORT=8118

# Security (required in production)
DJANGO_SECRET_KEY=

# Database (prefer DATABASE_URL)
# Example: postgresql://USER:PASSWORD@HOST:5432/DB
DATABASE_URL=
# Or explicit fields:
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Optional DB SSL config
DJANGO_DB_OPTIONS=      # JSON, e.g. {"sslmode":"require"}
DB_SSLMODE=
DB_SSLROOTCERT=
DB_SSLROOTCERT_B64=
DB_SSLCERT=
DB_SSLCERT_B64=
DB_SSLKEY=
DB_SSLKEY_B64=

# Paths
STATIC_ROOT=/app/staticfiles
DATA_DIR=/app/data
